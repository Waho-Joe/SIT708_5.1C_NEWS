<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".HomeFragment">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">
        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:scrollbars="none"
            android:layout_marginBottom="8dp">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/btnAll"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="All"
                    android:layout_marginEnd="6dp" />

                <Button
                    android:id="@+id/btnFootball"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Football"
                    android:layout_marginEnd="6dp" />

                <Button
                    android:id="@+id/btnBasketball"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Basketball"
                    android:layout_marginEnd="6dp" />

                <Button
                    android:id="@+id/btnCricket"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Cricket"
                    android:layout_marginEnd="6dp" />

            </LinearLayout>
        </HorizontalScrollView>
        <Button
            android:id="@+id/btnOpenBookmarks"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="View Bookmarks"
            android:layout_marginBottom="8dp" />
        <TextView
            android:id="@+id/topStories"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="TOP STORIES" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/featuredRecyclerView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

        <TextView
            android:id="@+id/news"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="NEWS" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/latestRecyclerView"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />
    </LinearLayout>
</FrameLayout>
